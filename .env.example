# Supabase — get these from https://app.supabase.com → your project → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OAuth (Phase 0.3 — configured later inside Supabase Auth providers)
# These are scheme/redirect helpers; provider client IDs/secrets live in Supabase, not the app.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_APPLE_SERVICE_ID=
