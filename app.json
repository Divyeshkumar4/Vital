{
  "expo": {
    "name": "Vital",
    "slug": "vital",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "vital",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vital.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.vital.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
